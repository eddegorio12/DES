---
// Footer.astro - Global site footer with company info, links, and contact details
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <!-- Company Info -->
      <div class="footer-section footer-about">
        <h3 class="footer-title">DES Engineering Services</h3>
        <p class="footer-description">
          Professional EC&I engineering services and manpower supply for industrial and commercial projects in Hong Kong.
        </p>
        <ul class="contact-list">
          <li>
            <strong>Phone:</strong>
            <a href="tel:+852XXXXXXXX" class="footer-link">+852 XXXX XXXX</a>
          </li>
          <li>
            <strong>Email:</strong>
            <a href="mailto:info@des-eng.com" class="footer-link">info@des-eng.com</a>
          </li>
          <li>
            <strong>Address:</strong>
            <address class="footer-address">
              Hong Kong SAR<br>
              (Full address to be added)
            </address>
          </li>
        </ul>
      </div>

      <!-- Quick Links -->
      <div class="footer-section footer-links">
        <h4 class="footer-heading">Quick Links</h4>
        <nav aria-label="Footer navigation">
          <ul class="footer-nav">
            <li><a href="/" class="footer-link">Home</a></li>
            <li><a href="/about" class="footer-link">About Us</a></li>
            <li><a href="/services" class="footer-link">Our Services</a></li>
            <li><a href="/contact" class="footer-link">Contact</a></li>
          </ul>
        </nav>
      </div>

      <!-- Services Summary -->
      <div class="footer-section footer-services">
        <h4 class="footer-heading">Services</h4>
        <ul class="footer-nav">
          <li><a href="/services/cable-tray-installation" class="footer-link">Cable Tray Installation</a></li>
          <li><a href="/services/cable-pulling" class="footer-link">Cable Pulling</a></li>
          <li><a href="/services/glanding-and-termination" class="footer-link">Glanding & Termination</a></li>
          <li><a href="/services/inspection" class="footer-link">Inspection</a></li>
          <li><a href="/services/maintenance" class="footer-link">Maintenance</a></li>
        </ul>
      </div>

      <!-- CTA Section -->
      <div class="footer-section footer-cta">
        <h4 class="footer-heading">Need a Quote?</h4>
        <p class="footer-cta-text">
          Contact us today to discuss your project requirements.
        </p>
        <a href="/contact" class="btn btn-primary">
          Request a Quote
        </a>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="footer-bottom">
      <p class="copyright">
        &copy; {new Date().getFullYear()} DES Engineering Services and Manpower Supply Limited. All rights reserved.
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--color-background-alt);
    border-top: 1px solid var(--color-border);
    padding: var(--spacing-2xl) 0 var(--spacing-lg);
    margin-top: auto;
  }

  .footer-grid {
    display: grid;
    gap: var(--spacing-xl);
    grid-template-columns: 1fr;
    margin-bottom: var(--spacing-xl);
  }

  @media (min-width: 768px) {
    .footer-grid {
      grid-template-columns: 1.5fr 1fr 1fr 1fr;
    }
  }

  .footer-title {
    font-size: 1.25rem;
    margin-bottom: var(--spacing-md);
    color: var(--color-primary);
  }

  .footer-heading {
    font-size: 1rem;
    margin-bottom: var(--spacing-md);
    color: var(--color-text);
  }

  .footer-description {
    color: var(--color-text-light);
    margin-bottom: var(--spacing-md);
    line-height: var(--line-height-base);
  }

  .contact-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .contact-list li {
    margin-bottom: var(--spacing-sm);
    color: var(--color-text-light);
  }

  .footer-address {
    font-style: normal;
    color: var(--color-text-light);
    line-height: var(--line-height-base);
  }

  .footer-nav {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer-nav li {
    margin-bottom: var(--spacing-sm);
  }

  .footer-link {
    color: var(--color-text-light);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .footer-link:hover {
    color: var(--color-primary);
    text-decoration: underline;
  }

  .footer-cta-text {
    color: var(--color-text-light);
    margin-bottom: var(--spacing-md);
  }

  .footer-bottom {
    padding-top: var(--spacing-lg);
    border-top: 1px solid var(--color-border);
    text-align: center;
  }

  .copyright {
    color: var(--color-text-light);
    font-size: 0.875rem;
    margin: 0;
  }
</style>
