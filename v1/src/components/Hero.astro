---
import { getCollection } from 'astro:content';

const projects = await getCollection('project');
const skills = await getCollection('skill');

const featuredProjects = projects.slice(0, 4);
const topSkills = skills.slice(0, 6);

const stats = [
  { label: 'Projects Completed', value: '25+' },
  { label: 'Happy Clients', value: '50+' },
  { label: 'Cups of Coffee', value: '1000+' },
  { label: 'Hours Coding', value: '5000+' }
];
---

<section class="hero section">
  <div class="container">
    <div class="flex items-center justify-between gap-8">
      <div class="flex-1">
        <h1 class="text-5xl md:text-6xl font-bold mb-6" style="color: #667eea;">Hi, I'm <span style="color: #4facfe;">John</span> Doe</h1>
        <p class="text-xl text-gray-600 mb-8 max-w-2xl">Full-stack developer passionate about creating beautiful, functional web applications that solve real-world problems.</p>
        <div class="flex gap-4 mb-8">
          <a href="#projects" class="btn btn-primary">View My Work</a>
          <a href="#contact" class="btn btn-secondary">Get In Touch</a>
        </div>
        <div class="flex gap-6">
          <a href="#" class="text-blue-600 hover:text-blue-800 transition-colors">
            <svg class="w-6 h-6 inline" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
