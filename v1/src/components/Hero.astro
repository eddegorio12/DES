            </svg>
          </a>
        </div>
      </div>
      <div class="flex-shrink-0 hidden md:block">
        <div class="relative">
          <div class="bg-gradient-to-br from-blue-400 to-purple-600 rounded-full h-96 w-96"></div>
          <div class="absolute inset-0 flex items-center justify-center">
            <div class="bg-white rounded-full h-80 w-80 flex items-center justify-center shadow-2xl">
              <div class="bg-gradient-to-br from-blue-400 to-purple-600 rounded-full h-72 w-72 flex items-center justify-center relative overflow-hidden">
                <div class="h-64 w-64 bg-white rounded-full flex items-center justify-center">
                  <div class="relative">
                    <div class="w-32 h-32 border-8 border-blue-400 rounded-full animate-spin"></div>
                    <div class="absolute inset-0 flex items-center justify-center">
                      <div class="bg-gradient-to-br from-blue-400 to-purple-600 rounded-full h-24 w-24 flex items-center justify-center">
                        <svg class="w-12 h-12 text-white" fill="currentColor" viewBox="0 0 20 20">
                          <path d="M10 2a6 6 0 00-6 6v3.586l-.707.707A1 1 0 004 14h12a1 1 0 00.707-1.707L16 11.586V8a6 6 0 00-6-6z" />
                        </svg>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes floating {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-20px); }
  }
  
  .animate-spin {
    animation: spin 2s linear infinite;
  }
  
  @keyframes spin {
    to { transform: rotate(360deg); }
  }
</style>