---
// CTABlock.astro - Modern call-to-action block
interface Props {
  title?: string;
  description?: string;
  buttonText: string;
  buttonLink: string;
}

const { 
  title = 'Ready to start your project?', 
  description = 'Contact us today to discuss your EC&I service needs and get a personalized quote.', 
  buttonText, 
  buttonLink 
} = Astro.props;
---

<section class="cta-block">
  <div class="container">
    <div class="cta-content">
      <h2 class="cta-title">{title}</h2>
      <p class="cta-description">{description}</p>
      <a href={buttonLink} class="btn btn-primary btn-lg">
        {buttonText}
      </a>
    </div>
  </div>
</section>

<style>
  .cta-block {
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
    color: white;
    padding: var(--spacing-3xl) 0;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .cta-block::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: radial-gradient(circle at 20% 80%, rgba(255, 255, 255, 0.1) 0%, transparent 50%),
                radial-gradient(circle at 80% 20%, rgba(255, 255, 255, 0.1) 0%, transparent 50%);
    pointer-events: none;
  }

  .cta-content {
    max-width: 700px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .cta-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    margin-bottom: var(--spacing-md);
    color: white;
    font-weight: var(--font-weight-black);
    line-height: var(--line-height-heading);
  }

  .cta-description {
    font-size: clamp(1rem, 2vw, 1.25rem);
    margin-bottom: var(--spacing-xl);
    opacity: 0.95;
    line-height: 1.7;
  }

  .cta-block :global(.btn-primary) {
    background-color: white;
    color: var(--color-primary);
    border-color: white;
    box-shadow: var(--shadow-lg);
    padding: var(--spacing-md) var(--spacing-2xl);
    font-size: 1.125rem;
    font-weight: var(--font-weight-bold);
  }

  .cta-block :global(.btn-primary:hover) {
    background-color: var(--color-background);
    color: var(--color-primary);
    border-color: var(--color-background);
    transform: translateY(-3px);
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.15);
  }

  .cta-block :global(.btn-primary:active) {
    transform: translateY(-1px);
    box-shadow: var(--shadow-md);
  }

  @media (max-width: 768px) {
    .cta-block {
      padding: var(--spacing-2xl) 0;
    }

    .cta-block :global(.btn-primary) {
      width: 100%;
      justify-content: center;
    }
  }
</style>
