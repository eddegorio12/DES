---
import { ContentCollectionEntry } from 'astro:content';

interface Props {
  skills: ContentCollectionEntry[];
}

const skillCategories = [
  { name: 'Frontend', color: '#667eea' },
  { name: 'Backend', color: '#f093fb' },
  { name: 'Tools', color: '#4facfe' },
  { name: 'Design', color: '#30cfd0' }
];

const skillsByCategory = skills.reduce((acc, skill) => {
  const category = skill.data.category || 'Frontend';
  if (!acc[category]) acc[category] = [];
  acc[category].push(skill);
  return acc;
}, {});

const skillCards = skills.map((skill) => ({
  name: skill.data.name,
  level: skill.data.level || 50,
  category: skill.data.category || 'Frontend',
  icon: skill.data.icon || '/placeholder-skill.svg'
}));

const topSkills = skillCards.slice(0, 8);
const otherSkills = skillCards.slice(8);
---

<section class="skills section bg-light">
  <div class="container">
    <div class="section-title">
      <h2>Skills & Expertise</h2>
      <p>Technologies and tools I work with to create amazing digital experiences</p>
    </div>
    
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-8">
      {skillCategories.map((category) => (
        <div class="skill-category text-center rounded-lg shadow-sm p-6 hover:shadow-md transition-all duration-300">
          <div class="w-16 h-16 bg-gradient-to-br from-{category.color}-light via-{category.color} to-{category.color}-dark rounded-full mx-auto mb-4 flex items-center justify-center text-white text-2xl">
            <svg class="w-10 h-10" fill="currentColor" viewBox="0 0 20 20">
              <path d="M10 2a6 6 0 00-6 6v3.586l-.707.707A1 1 0 004 14h12a1 1 0 00.707-1.707L16 11.586V8a6 6 0 00-6-6z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-2">{category.name}</h3>
          <p class="text-gray-600">{skillsByCategory[category.name]?.length || 0} skills</p>
        </div>
      ))}
    </div>
    
    <div class="text-center mb-8">
      <h3 class="text-2xl font-bold mb-6">Proficient Skills</h3>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
        {topSkills.map((skill) => (
          <div class="skill-item bg-white rounded-lg shadow-sm p-4 hover:shadow-md transition-all duration-300">
            <div class="flex items-center justify-between mb-2">
              <div class="w-8 h-8 bg-gradient-to-br from-{skill.category}-light via-{skill.category} to-{skill.category}-dark rounded-full flex items-center justify-center text-white text-sm">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M10 2a6 6 0 00-6 6v3.586l-.707.707A1 1 0 004 14h12a1 1 0 00.707-1.707L16 11.586V8a6 6 0 00-6-6z" />
                </svg>
              </div>
              <span class="text-sm font-medium text-gray-800">{skill.name}</span>
            </div>
            <div class="w-full bg-gray-200 rounded-full h-2 mb-2">
              <div class="bg-gradient-to-r from-{skill.category}-light via-{skill.category} to-{skill.category}-dark h-2 rounded-full" style={`width: ${skill.level}%`}></div>
            </div>
            <div class="text-xs text-gray-500">{skill.level}%</div>
          </div>
        ))}
      </div>
    </div>
    
    {otherSkills.length > 0 && (
      <div class="text-center">
        <h3 class="text-xl font-semibold text-gray-800 mb-4">Other Skills</h3>
        <div class="flex flex-wrap gap-2 justify-center">
          {otherSkills.map((skill) => (
            <span class="bg-gray-100 text-gray-600 px-4 py-2 rounded-full text-sm">{skill.name}</span>
          ))}
        </div>
      </div>
    )}
    
    <div class="text-center mt-8">
      <a href="/skills" class="btn btn-primary">View All Skills</a>
    </div>
  </div>
</section>

<style>
  .skill-category {
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
  
  .skill-category:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.1);
  }
  
  .skill-item {
    transition: all 0.2s ease;
  }
  
  .skill-item:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.1);
  }
</style>