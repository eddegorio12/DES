---
import { ContentCollectionEntry } from 'astro:content';

interface Props {
  projects: ContentCollectionEntry[];
}

const projectCards = projects.slice(0, 6).map((project) => ({
  title: project.data.title,
  description: project.data.description,
  technologies: project.data.technologies || [],
  link: project.data.link || '#',
  image: project.data.image || '/placeholder-project.jpg',
  liveUrl: project.data.liveUrl || '#',
  githubUrl: project.data.githubUrl || '#'
}));

const featuredProjects = projectCards.filter((_, index) => index < 3);
const additionalProjects = projectCards.filter((_, index) => index >= 3);
---

<section class="projects section">
  <div class="container">
    <div class="section-title">
      <h2>Featured Projects</h2>
      <p>Explore some of my recent work and client projects</p>
    </div>
    
    <div class="grid grid-cols-3 gap-8 mb-8">
      {featuredProjects.map((project) => (
        <div class="project-card rounded-lg shadow-lg overflow-hidden hover:shadow-xl transition-all duration-300">
          <div class="project-image h-64 bg-gray-200 bg-cover bg-center" style={`background-image: url('${project.image}')`}>
            <div class="project-overlay bg-black bg-opacity-0 transition-all duration-300 hover:bg-opacity-0.7 flex items-center justify-center">
              <div class="text-center opacity-0 transition-all duration-300 hover:opacity-100">
                <a href={project.liveUrl} target="_blank" rel="noopener noreferrer" class="btn btn-primary mb-4">Live Demo</a>
                <a href={project.githubUrl} target="_blank" rel="noopener noreferrer" class="btn btn-secondary">GitHub</a>
              </div>
            </div>
          </div>
          <div class="p-6">
            <h3 class="text-2xl font-bold mb-3">{project.title}</h3>
            <p class="text-gray-600 mb-4">{project.description}</p>
            <div class="flex flex-wrap gap-2 mb-4">
              {project.technologies.map((tech) => (
                <span class="bg-blue-100 text-blue-800 px-3 py-1 rounded-full text-sm">{tech}</span>
              ))}
            </div>
            <a href={project.link} class="btn btn-primary w-full">View Details</a>
          </div>
        </div>
      ))}
    </div>
    
    {additionalProjects.length > 0 && (
      <div class="text-center mb-8">
        <h3 class="text-xl font-semibold text-gray-800 mb-4">More Projects</h3>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
          {additionalProjects.map((project) => (
            <div class="project-thumbnail rounded-lg overflow-hidden shadow-sm hover:shadow-md transition-all duration-300">
              <div class="h-32 bg-gray-200 bg-cover bg-center" style={`background-image: url('${project.image}')`}></div>
              <div class="p-4">
                <h4 class="font-medium text-gray-800 mb-1">{project.title}</h4>
                <p class="text-sm text-gray-500">{project.technologies.slice(0, 2).join(', ')}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    )}
    
    <div class="text-center">
      <a href="/projects" class="btn btn-secondary">View All Projects</a>
    </div>
  </div>
</section>

<style>
  .project-card {
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
  
  .project-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);
  }
  
  .project-overlay {
    height: 100%;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
  
  .project-card:hover .project-overlay {
    transform: scale(1.05);
  }
  
  .project-thumbnail {
    transition: all 0.2s ease;
  }
  
  .project-thumbnail:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
  }
</style>