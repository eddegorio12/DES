---
// BaseLayout.astro - Standard page wrapper for all DES pages
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  currentPath?: string;
}

const { title, description = 'DES Engineering Services - Professional EC&I Services and Manpower Supply in Hong Kong', currentPath = '/' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | DES Engineering Services</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
  </head>
  <body>
    <Header currentPath={currentPath} />
    <main id="main-content" class="main-content">
      <div class="container">
        <slot /> {/* Page-specific content injected here */}
      </div>
    </main>
    <Footer />
  </body>
</html>

<style is:global>
  /* Base layout spacing rules */
  .main-content {
    padding: var(--spacing-2xl) 0;
    min-height: calc(100vh - 200px); /* Ensure footer stays at bottom */
  }

  @media (max-width: 768px) {
    .main-content {
      padding: var(--spacing-xl) 0;
    }
  }
</style>
