---
// Home page - fetches content from JSON file
import BaseLayout from '../layouts/BaseLayout.astro';
import CTABlock from '../components/CTABlock.astro';
import homeData from '../content/pages/home.json';

const { title, description, cta } = homeData;
---

<BaseLayout title={title} description={description} currentPath="/">
  <article class="home-page">
    <!-- Hero Section -->
    <section class="hero">
      <div class="container">
        <div class="hero-content">
          <h1 class="hero-title">{title}</h1>
          <p class="hero-subtitle">{description}</p>
          <div class="hero-ctas">
            {cta && (
              <a href={cta.link} class="btn btn-primary btn-lg">
                {cta.text}
              </a>
            )}
            <a href="/services" class="btn btn-secondary btn-lg">
              Explore Services
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Service Overview Section -->
    <section class="services-overview section-alt">
      <div class="container">
        <div class="section-header">
          <h2>Our Core Services</h2>
          <p class="section-subtitle">Comprehensive EC&I solutions for industrial and commercial projects</p>
        </div>
        <div class="services-grid">
          <div class="service-card">
            <h3>Cable Tray Installation</h3>
            <p>Professional installation of cable management systems for organized and safe wiring infrastructure.</p>
            <a href="/services/cable-tray-installation" class="service-link">
              Learn more <span aria-hidden="true">→</span>
            </a>
          </div>
          <div class="service-card">
            <h3>Cable Pulling</h3>
            <p>Precise cable pulling services with proper tension control and routing for optimal performance.</p>
            <a href="/services/cable-pulling" class="service-link">
              Learn more <span aria-hidden="true">→</span>
            </a>
          </div>
          <div class="service-card">
            <h3>Glanding and Termination</h3>
            <p>Expert cable termination and glanding ensuring secure connections and compliance with standards.</p>
            <a href="/services/glanding-and-termination" class="service-link">
              Learn more <span aria-hidden="true">→</span>
            </a>
          </div>
          <div class="service-card">
            <h3>Loop Check / Pre-Commissioning</h3>
            <p>Thorough loop checking and pre-commissioning to verify system integrity before operation.</p>
            <a href="/services/loop-check-pre-commissioning" class="service-link">
              Learn more <span aria-hidden="true">→</span>
            </a>
          </div>
          <div class="service-card">
            <h3>Instrument Configuration</h3>
            <p>Professional calibration and configuration of instrumentation for accurate measurements.</p>
            <a href="/services/instrument-configuration-calibration" class="service-link">
              Learn more <span aria-hidden="true">→</span>
            </a>
          </div>
          <div class="service-card">
            <h3>Inspection</h3>
            <p>Comprehensive inspection services to ensure compliance, safety, and system reliability.</p>
            <a href="/services/inspection" class="service-link">
              Learn more <span aria-hidden="true">→</span>
            </a>
          </div>
          <div class="service-card">
            <h3>Operation Support</h3>
            <p>On-demand technical support and operational assistance for EC&I systems.</p>
            <a href="/services/operation-support" class="service-link">
              Learn more <span aria-hidden="true">→</span>
            </a>
          </div>
          <div class="service-card">
            <h3>Maintenance</h3>
            <p>Preventive and corrective maintenance services to keep your systems running efficiently.</p>
            <a href="/services/maintenance" class="service-link">
              Learn more <span aria-hidden="true">→</span>
            </a>
          </div>
        </div>
        <div class="services-cta">
          <a href="/services" class="btn btn-secondary btn-lg">
            View All Services
          </a>
        </div>
      </div>
    </section>

    <!-- Why DES Section -->
    <section class="why-des">
      <div class="container">
        <div class="section-header">
          <h2>Why Choose DES</h2>
          <p class="section-subtitle">Experience and expertise you can trust</p>
        </div>
        <div class="benefits-grid">
          <div class="benefit-card">
            <div class="benefit-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M9 12L11 14L15 10M21 12C21 16.9706 16.9706 21 12 21C7.02944 21 3 16.9706 3 12C3 7.02944 7.02944 3 12 3C16.9706 3 21 7.02944 21 12Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3>Registered & Certified</h3>
            <p>Fully licensed engineering services company with proven industry credentials.</p>
          </div>
          <div class="benefit-card">
            <div class="benefit-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 6V12L16 14M22 12C22 17.5228 17.5228 22 12 22C6.47715 22 2 17.5228 2 12C2 6.47715 6.47715 2 12 2C17.5228 2 22 6.47715 22 12Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3>Experienced Team</h3>
            <p>Skilled engineers and technicians with extensive industrial project expertise.</p>
          </div>
          <div class="benefit-card">
            <div class="benefit-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M9 12L11 14L15 10M21 12C21 16.9706 16.9706 21 12 21C7.02944 21 3 16.9706 3 12C3 7.02944 7.02944 3 12 3C16.9706 3 21 7.02944 21 12Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3>Safety-First Culture</h3>
            <p>Strict adherence to safety protocols on every project, protecting everyone on site.</p>
          </div>
          <div class="benefit-card">
            <div class="benefit-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M13 10V3L4 14H11V21L20 10H13Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3>Responsive Delivery</h3>
            <p>Flexible resources and rapid response to meet your project timelines.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Trust Signals Section -->
    <section class="trust-signals section-alt">
      <div class="container">
        <div class="section-header">
          <h2>Our Track Record</h2>
          <p class="section-subtitle">Proven capability across diverse industries</p>
        </div>
        <div class="stats-grid">
          <div class="stat-card">
            <div class="stat-number">8+</div>
            <div class="stat-label">Years Experience</div>
          </div>
          <div class="stat-card">
            <div class="stat-number">50+</div>
            <div class="stat-label">Projects Completed</div>
          </div>
          <div class="stat-card">
            <div class="stat-number">100%</div>
            <div class="stat-label">Safety Commitment</div>
          </div>
          <div class="stat-card">
            <div class="stat-number">24/7</div>
            <div class="stat-label">Support Available</div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <CTABlock 
      title="Ready to start your project?" 
      description="Let us help you achieve your EC&I project goals with our professional services."
      buttonText="Discuss Your Project"
      buttonLink="/contact" 
    />
  </article>
</BaseLayout>

<style>
  /* ==========================================================================
     Professional Front-End Optimizations
     ========================================================================== */

  /* Performance Optimizations */
  .hero, .why-des, .trust-signals {
    will-change: transform, opacity;
  }

  .service-card, .benefit-card, .stat-card {
    will-change: transform, box-shadow;
  }

  /* Advanced CSS Custom Properties */
  :root {
    --timing-fast: 0.15s;
    --timing-normal: 0.3s;
    --timing-slow: 0.5s;
    --easing-smooth: cubic-bezier(0.4, 0, 0.2, 1);
    --easing-bounce: cubic-bezier(0.68, -0.55, 0.265, 1.55);
    --easing-elastic: cubic-bezier(0.68, -0.55, 0.265, 1.55);
  }

  /* Enhanced Hover States */
  .service-card {
    transition: all var(--timing-normal) var(--easing-smooth);
    position: relative;
    overflow: hidden;
  }

  .service-card::after {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.1), transparent);
    transition: left var(--timing-normal) var(--easing-smooth);
  }

  .service-card:hover::after {
    left: 100%;
  }

  .service-card:hover {
    transform: translateY(-8px) scale(1.01);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);
    border-color: var(--color-primary);
  }

  /* Professional Button Enhancements */
  .btn {
    transition: all var(--timing-normal) var(--easing-smooth);
    position: relative;
    overflow: hidden;
  }

  .btn::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.1), transparent);
    transition: left var(--timing-normal) var(--easing-smooth);
  }

  .btn:hover::before {
    left: 100%;
  }

  .btn:active {
    transform: scale(0.98);
    transition: transform var(--timing-fast) var(--easing-smooth);
  }

  .btn-primary:hover {
    transform: translateY(-2px) scale(1.02);
    box-shadow: 0 12px 30px rgba(0, 102, 204, 0.3);
  }

  .btn-secondary:hover {
    transform: translateY(-2px) scale(1.02);
    box-shadow: 0 8px 25px rgba(0, 102, 204, 0.2);
  }

  /* Advanced Card Animations */
  .benefit-card {
    transition: all var(--timing-normal) var(--easing-smooth);
    position: relative;
    overflow: hidden;
  }

  .benefit-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(135deg, transparent, rgba(0, 102, 204, 0.05), transparent);
    opacity: 0;
    transition: opacity var(--timing-normal) var(--easing-smooth);
  }

  .benefit-card:hover::before {
    opacity: 1;
  }

  .benefit-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.15);
  }

  /* Enhanced Stat Cards */
  .stat-card {
    transition: all var(--timing-normal) var(--easing-smooth);
    position: relative;
    overflow: hidden;
  }

  .stat-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(0, 102, 204, 0.1), transparent);
    transition: left var(--timing-normal) var(--easing-smooth);
  }

  .stat-card:hover::before {
    left: 100%;
  }

  .stat-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);
  }

  /* Professional Icon Animations */
  .benefit-icon {
    transition: all var(--timing-normal) var(--easing-smooth);
  }

  .benefit-card:hover .benefit-icon {
    transform: scale(1.1) rotate(5deg);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.1);
  }

  /* Enhanced Text Effects */
  .hero-title, .hero-subtitle {
    transition: all var(--timing-normal) var(--easing-smooth);
  }

  .hero-title:hover, .hero-subtitle:hover {
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  /* Advanced Responsive Design */
  @media (max-width: 768px) {
    .hero {
      padding: var(--spacing-2xl) 0;
    }

    .hero-ctas .btn {
      width: 100%;
      justify-content: center;
    }

    .section-header {
      margin-bottom: var(--spacing-xl);
    }

    .services-grid {
      gap: var(--spacing-md);
    }

    .benefits-grid {
      gap: var(--spacing-md);
    }

    .trust-signals {
      padding: var(--spacing-2xl) 0;
    }

    /* Mobile-optimized animations */
    .service-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 8px 20px rgba(0, 0, 0, 0.1);
    }

    .benefit-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 8px 20px rgba(0, 0, 0, 0.1);
    }

    .stat-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 8px 20px rgba(0, 0, 0, 0.1);
    }
  }

  /* Performance Optimizations */
  .hero, .why-des, .trust-signals {
    will-change: transform, opacity;
  }

  .service-card, .benefit-card, .stat-card {
    will-change: transform, box-shadow;
  }

  /* CSS Containment for Performance */
  .hero {
    contain: layout style paint;
  }

  .services-grid, .benefits-grid, .stats-grid {
    contain: layout style;
  }

  /* Advanced Scroll Animations */
  .animate-fade-in-up {
    opacity: 0;
    transform: translateY(30px);
    animation: fadeInUp 1s ease-out forwards;
    will-change: opacity, transform;
  }

  .animate-fade-in {
    opacity: 0;
    animation: fadeIn 1s ease-out forwards;
    will-change: opacity;
  }

  /* Professional Loading States */
  .loading {
    position: relative;
    overflow: hidden;
  }

  .loading::after {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
    animation: loading 1.5s infinite;
  }

  /* Enhanced Focus States */
  .btn:focus, .form-input:focus, .form-select:focus, .form-textarea:focus {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
    animation: glow 0.5s ease-out forwards;
  }

  /* Professional Error Handling */
  .form-error {
    border-color: var(--color-error);
    background-color: var(--color-error-light);
    transition: all var(--timing-normal) var(--easing-smooth);
  }

  .form-error:focus {
    box-shadow: 0 0 0 4px rgba(239, 68, 68, 0.1);
    transform: translateY(-2px);
  }

  /* Advanced Accessibility Features */
  .sr-only:focus {
    position: static;
    width: auto;
    height: auto;
    padding: var(--spacing-sm);
    margin: 0;
    overflow: visible;
    clip: auto;
    white-space: normal;
    border: 1px solid var(--color-primary);
    background: var(--color-background);
    color: var(--color-text);
  }

  /* Professional Touch Interactions */
  .touch-device .service-card:hover,
  .touch-device .benefit-card:hover,
  .touch-device .stat-card:hover {
    transform: none;
    box-shadow: var(--shadow-sm);
  }

  .touch-device .service-card:active,
  .touch-device .benefit-card:active,
  .touch-device .stat-card:active {
    transform: scale(0.98);
    transition: transform var(--timing-fast) var(--easing-smooth);
  }

  /* Advanced CSS Features */
  @supports (animation: var(--custom-animation)) {
    /* Modern CSS Custom Properties for Animations */
    @keyframes customAnimation {
      from {
        opacity: 0;
        transform: translateY(30px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .animate-custom {
      animation: customAnimation var(--timing-normal) var(--easing-smooth) forwards;
    }
  }

  /* Professional Print Styles */
  @media print {
    .hero, .why-des, .trust-signals {
      background: transparent !important;
      box-shadow: none !important;
    }

    .service-card, .benefit-card, .stat-card {
      border: 1px solid #ccc;
      box-shadow: none !important;
    }

    .btn {
      background: #ccc !important;
      color: #000 !important;
    }
  }
</style>
