                        <a href="#contact" class="btn btn-primary">{ctaContent.primaryBtn}</a>
                        <a href="tel:+852-2123-4567" class="btn btn-secondary">{ctaContent.secondaryBtn}</a>
                    </div>
                </div>
            </div>
        </section>
        
        <!-- Contact Information -->
        <section id="contact" class="section">
            <div class="container">
                <div class="text-center mb-12">
                    <h2 class="text-4xl font-bold mb-6">Get in Touch</h2>
                    <p class="text-xl text-gray-600 max-w-3xl mx-auto">Ready to discuss your project? We're here to help.</p>
                </div>
                
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
                    <div>
                        <form class="bg-white rounded-lg shadow-lg p-8">
                            <div class="mb-6">
                                <label class="block text-gray-700 font-semibold mb-2" for="name">Name</label>
                                <input class="form-input w-full" type="text" id="name" name="name" placeholder="Your Name" required>
                            </div>
                            <div class="mb-6">
                                <label class="block text-gray-700 font-semibold mb-2" for="company">Company</label>
                                <input class="form-input w-full" type="text" id="company" name="company" placeholder="Your Company" required>
                            </div>
                            <div class="mb-6">
                                <label class="block text-gray-700 font-semibold mb-2" for="email">Email</label>
                                <input class="form-input w-full" type="email" id="email" name="email" placeholder="your.email@example.com" required>
                            </div>
                            <div class="mb-6">
                                <label class="block text-gray-700 font-semibold mb-2" for="phone">Phone</label>
                                <input class="form-input w-full" type="tel" id="phone" name="phone" placeholder="+852 2123 4567" required>
                            </div>
                            <div class="mb-6">
                                <label class="block text-gray-700 font-semibold mb-2" for="service">Service Needed</label>
                                <select class="form-select w-full" id="service" name="service" required>
                                    <option value="">Select a Service</option>
                                    <option value="cable-tray">Cable Tray Installation</option>
                                    <option value="cable-pulling">Cable Pulling</option>
                                    <option value="glanding">Glanding & Termination</option>
                                    <option value="loop-check">Loop Check & Pre-Commissioning</option>
                                    <option value="instrument">Instrument Configuration</option>
                                    <option value="inspection">Inspection Services</option>
                                    <option value="maintenance">Maintenance Services</option>
                                    <option value="other">Other</option>
                                </select>
                            </div>
                            <div class="mb-6">
                                <label class="block text-gray-700 font-semibold mb-2" for="project">Project Details</label>
                                <textarea class="form-textarea w-full" id="project" name="project" placeholder="Tell us about your project requirements..." rows="4" required></textarea>
                            </div>
                            <button type="submit" class="btn btn-primary w-full">Send Inquiry</button>
                        </form>
                    </div>
                    <div>
                        <div class="contact-cta">
                            <h3 class="text-2xl font-bold mb-4">Contact Information</h3>
                            <div class="space-y-6">
                                <div>
                                    <h4 class="font-semibold mb-2">Hong Kong Office</h4>
                                    <p class="text-gray-600">Unit 1001, 10/F, Tower 1, 
                                    <br>Enterprise Square Three,
                                    <br>9 Sheung Yuet Road,
                                    <br>Kowloon Bay, Hong Kong</p>
                                </div>
                                <div>
                                    <h4 class="font-semibold mb-2">Phone</h4>
                                    <p class="text-gray-600 phone">+852 2123 4567</p>
                                    <a href="mailto:info@des.com.hk" class="text-blue-600 hover:text-blue-800 transition-colors">info@des.com.hk</a>
                                </div>
                                <div>
                                    <h4 class="font-semibold mb-2">Business Hours</h4>
                                    <p class="text-gray-600">Monday - Friday: 9:00 AM - 6:00 PM
                                    <br>Saturday: 9:00 AM - 1:00 PM
                                    <br>Sunday & Public Holidays: Closed</p>
                                </div>
                                <div class="contact-cta">
                                    <h4 class="font-semibold mb-2">Emergency Support</h4>
                                    <p class="text-gray-600">Available 24/7 for urgent situations</p>
                                    <div class="whatsapp">
                                        <svg fill="currentColor" viewBox="0 0 20 20">
                                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.414L11 9.586V6z" clip-rule="evenodd"/>
                                        </svg>
                                        +852 5123 4567
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>
    
