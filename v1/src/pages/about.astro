---
// About page - fetches content from JSON file
import BaseLayout from '../layouts/BaseLayout.astro';
import CTABlock from '../components/CTABlock.astro';
import aboutData from '../content/pages/about.json';

const { title, description, cta } = aboutData;
---

<BaseLayout title={title} description={description} currentPath="/about">
  <article class="about-page">
    <header class="page-hero">
      <div class="container">
        <h1>{title}</h1>
        <p class="page-subtitle">{description}</p>
      </div>
    </header>

    <div class="container">
      <section class="company-overview">
        <div class="overview-content">
          <h2>Who We Are</h2>
          <p>DES Engineering Services and Manpower Supply Limited is a Hong Kong-based company providing professional engineering services and skilled manpower for electrical, control, and instrumentation (EC&I) projects.</p>
          <p>We support contractors, project managers, and industrial clients with reliable technical services that keep projects on track, on time, and within budget.</p>
        </div>
      </section>

      <section class="mission-vision-values">
        <div class="mv-grid">
          <div class="mission card">
            <div class="card-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 2L2 7L12 12L22 7L12 2Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M2 17L12 22L22 17" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M2 12L12 17L22 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3>Our Mission</h3>
            <p>To deliver dependable engineering services and skilled manpower that meet the highest standards of safety, quality, and professionalism.</p>
          </div>
          
          <div class="vision card">
            <div class="card-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M1 12S5 3 12 3s11 9 11 9-4 9-11 9-11-9-11-9z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="2"/>
              </svg>
            </div>
            <h3>Our Vision</h3>
            <p>To be the trusted EC&I services partner of choice for industrial and commercial projects across the region.</p>
          </div>
        </div>
      </section>

      <section class="core-values">
        <h2>Our Values</h2>
        <div class="values-grid">
          <div class="value-item">
            <div class="value-icon">P</div>
            <div class="value-content">
              <h3>Professionalism</h3>
              <p>We conduct all work with technical excellence and integrity</p>
            </div>
          </div>
          <div class="value-item">
            <div class="value-icon">R</div>
            <div class="value-content">
              <h3>Reliability</h3>
              <p>We deliver on our commitments, on time and within scope</p>
            </div>
          </div>
          <div class="value-item">
            <div class="value-icon">S</div>
            <div class="value-content">
              <h3>Safety</h3>
              <p>We protect our team, our clients, and our reputation through safe work practices</p>
            </div>
          </div>
          <div class="value-item">
            <div class="value-icon">Q</div>
            <div class="value-content">
              <h3>Quality</h3>
              <p>We maintain high standards in every task we perform</p>
            </div>
          </div>
        </div>
      </section>

      <section class="why-clients section-alt">
        <h2>Why Clients Choose DES</h2>
        <div class="benefits-grid">
          <div class="benefit-item card">
            <h3>Experienced Team</h3>
            <p>Our engineers and technicians bring deep industry knowledge to every project.</p>
          </div>
          <div class="benefit-item card">
            <h3>Flexible Manpower</h3>
            <p>We provide skilled resources that match your project scale and timeline.</p>
          </div>
          <div class="benefit-item card">
            <h3>End-to-End Support</h3>
            <p>From installation to commissioning to ongoing maintenance.</p>
          </div>
          <div class="benefit-item card">
            <h3>Local Expertise</h3>
            <p>We understand the Hong Kong market and project environment intimately.</p>
          </div>
        </div>
      </section>

      <section class="safety-quality">
        <div class="sq-content">
          <h2>Commitment to Safety & Quality</h2>
          <p>DES maintains strict safety protocols and quality control procedures on all projects. Our team follows recognized industry standards and site-specific requirements to ensure work is performed correctly and safely.</p>
          <p>Every team member is trained in site safety, and we conduct thorough risk assessments before starting any work. Quality is never compromised—we verify every connection, test every system, and document every step.</p>
        </div>
      </section>

      <CTABlock 
        title="Ready to work with DES?" 
        description="Contact us today to discuss your project needs and get a free consultation."
        buttonText="Get in Touch"
        buttonLink="/contact" 
      />
    </div>
  </article>
</BaseLayout>

<style>
  .page-hero {
    background: linear-gradient(180deg, var(--color-background-alt) 0%, var(--color-background) 100%);
    padding: var(--spacing-3xl) 0 var(--spacing-2xl);
    text-align: center;
    border-bottom: 1px solid var(--color-border-light);
    position: relative;
    overflow: hidden;
    contain: layout style paint;
  }

  .page-hero::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 100%;
    background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='%23f8fafc' fill-opacity='0.1'%3E%3Cpath d='M36 36c4.418 0 8-3.582 8-8s-3.582-8-8-8-8 3.582-8 8 3.582 8 8 8zm0-14c2.206 0 4 1.794 4 4s-1.794 4-4 4-4-1.794-4-4 1.794-4 4-4zM24 36c4.418 0 8-3.582 8-8s-3.582-8-8-8-8 3.582-8 8 3.582 8 8 8zm0-14c2.206 0 4 1.794 4 4s-1.794 4-4 4-4-1.794-4-4 1.794-4 4-4zM12 36c4.418 0 8-3.582 8-8s-3.582-8-8-8-8 3.582-8 8 3.582 8 8 8zm0-14c2.206 0 4 1.794 4 4s-1.794 4-4 4-4-1.794-4-4 1.794-4 4-4z'/%3E%3C/g%3E%3C/svg%3E") repeat;
    opacity: 0;
    animation: fadeIn 2s ease-out forwards;
    will-change: opacity;
  }

  .page-hero h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: var(--spacing-md);
    letter-spacing: -0.03em;
    opacity: 0;
    transform: translateY(30px);
    animation: fadeInUp 1s ease-out 0.5s forwards;
    will-change: opacity, transform;
  }

  .page-subtitle {
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: var(--color-text-light);
    max-width: 700px;
    margin: 0 auto;
    line-height: 1.6;
    opacity: 0;
    transform: translateY(30px);
    animation: fadeInUp 1s ease-out 0.8s forwards;
    will-change: opacity, transform;
  }

  .container {
    max-width: var(--container-max-width);
    margin: 0 auto;
    padding: 0 var(--container-padding);
    contain: layout style;
  }

  section {
    margin-bottom: var(--spacing-3xl);
    opacity: 0;
    transform: translateY(20px);
    animation: fadeInUp 0.8s ease-out forwards;
    will-change: opacity, transform;
  }

  h2 {
    font-size: clamp(1.5rem, 4vw, 2rem);
    margin-bottom: var(--spacing-xl);
    text-align: center;
    color: var(--color-text);
    opacity: 0;
    transform: translateY(20px);
    animation: fadeInUp 0.8s ease-out forwards;
    will-change: opacity, transform;
  }

  p {
    line-height: 1.7;
    margin-bottom: var(--spacing-md);
    color: var(--color-text-light);
  }

  /* Overview */
  .overview-content {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
    opacity: 0;
    transform: translateY(20px);
    animation: fadeInUp 0.8s ease-out 0.2s forwards;
    will-change: opacity, transform;
  }

  .overview-content h2 {
    font-size: var(--font-size-h3);
  }

  /* Mission/Vision Grid */
  .mv-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--spacing-xl);
    opacity: 0;
    transform: translateY(20px);
    animation: fadeInUp 0.8s ease-out 0.4s forwards;
    will-change: opacity, transform;
  }

  .mission, .vision {
    padding: var(--spacing-xl);
    background: var(--color-background-card);
    border-radius: var(--border-radius-lg);
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--color-border-light);
    position: relative;
    overflow: hidden;
    contain: layout style paint;
  }

  .mission::before, .vision::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle, rgba(0, 102, 204, 0.05) 0%, transparent 70%);
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  .mission:hover::before, .vision:hover::before {
    opacity: 1;
  }

  .mission h3, .vision h3 {
    font-size: 1.25rem;
    margin-bottom: var(--spacing-md);
    color: var(--color-primary);
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    transition: color var(--transition-fast);
  }

  .mission h3:hover, .vision h3:hover {
    color: var(--color-primary-dark);
  }

  .card-icon {
    width: 48px;
    height: 48px;
    background: var(--color-primary-light);
    color: var(--color-primary);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--spacing-md);
    transition: all var(--transition-fast);
  }

  .mission:hover .card-icon, .vision:hover .card-icon {
    transform: scale(1.1);
    box-shadow: var(--shadow-md);
  }

  /* Values Grid */
  .values-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--spacing-lg);
    opacity: 0;
    transform: translateY(20px);
    animation: fadeInUp 0.8s ease-out 0.6s forwards;
    will-change: opacity, transform;
  }

  .value-item {
    display: flex;
    gap: var(--spacing-md);
    padding: var(--spacing-lg);
    background: var(--color-background-alt);
    border-radius: var(--border-radius-lg);
    position: relative;
    overflow: hidden;
    contain: layout style paint;
  }

  .value-item::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle, rgba(0, 102, 204, 0.05) 0%, transparent 70%);
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  .value-item:hover::before {
    opacity: 1;
  }

  .value-item:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .value-icon {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    background: var(--color-primary);
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: var(--font-weight-bold);
    font-size: 1rem;
    transition: all var(--transition-fast);
  }

  .value-item:hover .value-icon {
    transform: scale(1.1);
  }

  .value-content h3 {
    font-size: 1rem;
    margin-bottom: var(--spacing-xs);
    transition: color var(--transition-fast);
  }

  .value-content p {
    font-size: 0.875rem;
    margin-bottom: 0;
    color: var(--color-text-light);
  }

  /* Benefits Grid */
  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: var(--spacing-lg);
    opacity: 0;
    transform: translateY(20px);
    animation: fadeInUp 0.8s ease-out 0.8s forwards;
    will-change: opacity, transform;
  }

  .benefit-item {
    padding: var(--spacing-lg);
    background: var(--color-background-card);
    border-radius: var(--border-radius-lg);
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--color-border-light);
    position: relative;
    overflow: hidden;
    contain: layout style paint;
  }

  .benefit-item::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle, rgba(0, 102, 204, 0.05) 0%, transparent 70%);
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  .benefit-item:hover::before {
    opacity: 1;
  }

  .benefit-item:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    border-color: var(--color-primary);
  }

  .benefit-item h3 {
    font-size: 1.125rem;
    margin-bottom: var(--spacing-sm);
    color: var(--color-text);
    transition: color var(--transition-fast);
  }

  .benefit-item:hover h3 {
    color: var(--color-primary);
  }

  .benefit-item p {
    margin-bottom: 0;
  }

  /* Safety & Quality */
  .safety-quality {
    background: var(--color-primary-light);
    padding: var(--spacing-2xl);
    border-radius: var(--border-radius-xl);
    border-left: 4px solid var(--color-primary);
    position: relative;
    overflow: hidden;
    contain: layout style paint;
  }

  .safety-quality::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 100%;
    background: linear-gradient(135deg, transparent, rgba(0, 102, 204, 0.1), transparent);
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  .safety-quality:hover::before {
    opacity: 1;
  }

  .sq-content h2 {
    text-align: left;
    margin-bottom: var(--spacing-lg);
    opacity: 0;
    transform: translateY(20px);
    animation: fadeInUp 0.8s ease-out 0.2s forwards;
    will-change: opacity, transform;
  }

  .sq-content p {
    font-size: 1.0625rem;
    opacity: 0;
    transform: translateY(20px);
    animation: fadeInUp 0.8s ease-out 0.4s forwards;
    will-change: opacity, transform;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .page-hero {
      padding: var(--spacing-xl) 0;
    }

    section {
      margin-bottom: var(--spacing-xl);
    }

    h2 {
      margin-bottom: var(--spacing-lg);
    }

    .values-grid,
    .benefits-grid {
      gap: var(--spacing-md);
    }

    .safety-quality {
      padding: var(--spacing-lg);
    }

    /* Mobile-optimized animations */
    .mission:hover, .vision:hover {
      transform: translateY(-4px);
      box-shadow: var(--shadow-md);
    }

    .value-item:hover {
      transform: translateY(-4px);
      box-shadow: var(--shadow-md);
    }

    .benefit-item:hover {
      transform: translateY(-4px);
      box-shadow: var(--shadow-md);
      border-color: var(--color-border-light);
    }

    .safety-quality:hover {
      transform: translateY(-4px);
      box-shadow: var(--shadow-md);
    }
  }
</style>
