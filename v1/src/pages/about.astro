---
// About page - fetches content from JSON file
import BaseLayout from '../layouts/BaseLayout.astro';
import CTABlock from '../components/CTABlock.astro';
import aboutData from '../content/pages/about.json';

const { title, description, cta } = aboutData;
---

<BaseLayout title={title} description={description}>
  <article class="about-page">
    <header class="page-header">
      <h1>{title}</h1>
    </header>

    <div class="content">
      <section class="company-overview">
        <h2>Company Overview</h2>
        <p>DES Engineering Services and Manpower Supply Limited is a Hong Kong-based company providing professional engineering services and skilled manpower for electrical, control, and instrumentation (EC&I) projects.</p>
        <p>We support contractors, project managers, and industrial clients with reliable technical services that keep projects on track.</p>
      </section>

      <section class="mission-vision">
        <div class="mv-grid">
          <div class="mission">
            <h2>Our Mission</h2>
            <p>To deliver dependable engineering services and skilled manpower that meet the highest standards of safety, quality, and professionalism.</p>
          </div>
          <div class="vision">
            <h2>Our Vision</h2>
            <p>To be the trusted EC&I services partner of choice for industrial and commercial projects across the region.</p>
          </div>
        </div>
      </section>

      <section class="core-values">
        <h2>Core Values</h2>
        <ul class="values-list">
          <li>
            <strong>Professionalism</strong>
            <p>We conduct all work with technical excellence and integrity</p>
          </li>
          <li>
            <strong>Reliability</strong>
            <p>We deliver on our commitments, on time and within scope</p>
          </li>
          <li>
            <strong>Safety</strong>
            <p>We protect our team, our clients, and our reputation through safe work practices</p>
          </li>
          <li>
            <strong>Quality</strong>
            <p>We maintain high standards in every task we perform</p>
          </li>
        </ul>
      </section>

      <section class="why-clients">
        <h2>Why Clients Choose DES</h2>
        <ul class="benefits-list">
          <li>Experienced Team: Our engineers and technicians bring deep industry knowledge</li>
          <li>Flexible Manpower: We provide skilled resources that match your project scale</li>
          <li>End-to-End Support: From installation to commissioning to maintenance</li>
          <li>Local Presence: We understand the Hong Kong market and project environment</li>
        </ul>
      </section>

      <section class="safety-quality">
        <h2>Safety and Quality Commitment</h2>
        <p>DES maintains strict safety protocols and quality control procedures on all projects. Our team follows recognized industry standards and site-specific requirements to ensure work is performed correctly and safely.</p>
      </section>

      <CTABlock 
        title="Ready to work with DES?" 
        description="Contact us today to discuss your project needs."
        buttonText="Get in Touch"
        buttonLink="/contact" 
      />
    </div>
  </article>
</BaseLayout>

<style>
  .page-header {
    background-color: var(--color-background-alt);
    padding: var(--spacing-2xl) 0;
    margin-bottom: var(--spacing-2xl);
  }

  .page-header h1 {
    margin: 0;
    text-align: center;
  }

  .content {
    max-width: 900px;
    margin: 0 auto;
  }

  section {
    margin-bottom: var(--spacing-2xl);
  }

  h2 {
    color: var(--color-primary);
    margin-bottom: var(--spacing-md);
    font-size: var(--font-size-h3);
  }

  p {
    line-height: var(--line-height-base);
    margin-bottom: var(--spacing-md);
    color: var(--color-text);
  }

  .mission-vision {
    padding: var(--spacing-xl) 0;
  }

  .mv-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--spacing-xl);
  }

  .mission, .vision {
    padding: var(--spacing-lg);
    background-color: var(--color-background-alt);
    border-radius: 4px;
  }

  .mission h2, .vision h2 {
    font-size: var(--font-size-h4);
  }

  .values-list, .benefits-list {
    list-style: none;
    padding: 0;
  }

  .values-list li, .benefits-list li {
    padding: var(--spacing-md) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .values-list li:last-child, .benefits-list li:last-child {
    border-bottom: none;
  }

  .values-list li strong {
    color: var(--color-primary);
    display: block;
    margin-bottom: var(--spacing-sm);
  }

  .safety-quality {
    background-color: var(--color-background-alt);
    padding: var(--spacing-xl);
    border-radius: 4px;
    border-left: 4px solid var(--color-primary);
  }

  @media (max-width: 768px) {
    .page-header {
      padding: var(--spacing-xl) 0;
    }

    section {
      margin-bottom: var(--spacing-xl);
    }
  }
</style>
